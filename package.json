{
  "name": "branchpoint",
  "version": "0.2.0",
  "description": "MCP server that gives AI coding agents persistent, git-branch-aware context",
  "main": "index.js",
  "bin": {
    "branchpoint": "./dist/index.js"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsdown --config-loader native",
    "test": "pnpm build && vitest run"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "git",
    "ai-agents",
    "developer-tools",
    "claude-code"
  ],
  "author": "Caarlosgg",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Caarlosgg/branchpoint.git"
  },
  "homepage": "https://github.com/Caarlosgg/branchpoint",
  "bugs": {
    "url": "https://github.com/Caarlosgg/branchpoint/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.10.0",
      "onFail": "download"
    }
  },
  "type": "module",
  "dependencies": {
    "@clack/prompts": "^1.7.0",
    "@modelcontextprotocol/sdk": "1.29.0",
    "boxen": "^8.0.1",
    "cli-table3": "^0.6.5",
    "commander": "^15.0.0",
    "picocolors": "^1.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@types/node": "^26.1.1",
    "tsdown": "^0.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
